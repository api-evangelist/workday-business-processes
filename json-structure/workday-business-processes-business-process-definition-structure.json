{
  "$schema": "https://json-structure.org/meta/extended/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/workday-business-processes/refs/heads/main/json-structure/workday-business-processes-business-process-definition-structure.json",
  "title": "Business Process Definition",
  "description": "A Workday business process type definition with steps and configuration",
  "type": "object",
  "properties": {
    "id": {
      "description": "Unique definition identifier",
      "type": "string"
    },
    "name": {
      "description": "Business process name",
      "type": "string"
    },
    "type": {
      "description": "Business process type identifier",
      "type": "string"
    },
    "status": {
      "description": "Definition status",
      "type": "string",
      "enum": [
        "ACTIVE",
        "INACTIVE",
        "DRAFT"
      ]
    },
    "version": {
      "description": "Definition version number",
      "type": "int32"
    },
    "description": {
      "description": "Process description",
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "type",
    "status"
  ]
}